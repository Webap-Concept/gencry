# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
BASE_URL=http://localhost:3000
AUTH_SECRET=***
# 32 byte chiave per cifrare i secret TOTP a riposo (AES-256-GCM).
# Generala con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MFA_ENCRYPTION_KEY=***

# Default locale per l'app — install-time config.
# Determina la lingua servita su URL senza prefix (es. "/" per la landing
# pubblica e tutte le route auth/admin/loggati che non hanno prefix).
# Le altre lingue sono accessibili via slug per le pagine pubbliche
# (es. "/en/about" per la versione inglese di una CMS page).
# Valori validi: en, it. Default se non settata: it (Gencry).
# Customer white-label setta esplicitamente la propria lingua qui.
# Cambiarla dopo il go-live ha impatto SEO ed è sconsigliato.
I18N_DEFAULT_LOCALE=it